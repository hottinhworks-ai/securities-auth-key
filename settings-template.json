{
  "//": "Template merge vào .claude/settings.json của project (dùng install.mjs để merge tự động).",
  "//layers": "Lớp 1: permissions.deny — harness cưỡng chế, áp dụng cho tool Read của Claude Code, KHÔNG ảnh hưởng tool mcp__*. Lớp 2: PreToolUse hook — xử lý các case cần allowlist tinh hơn (.env.example, .mcp.json...).",
  "permissions": {
    "deny": [
      "Read(./.env)",
      "Read(**/.env)",
      "Read(./.env.local)",
      "Read(./.env.production)",
      "Read(./.env.staging)",
      "Read(./.env.development)",
      "Read(**/*.pem)",
      "Read(**/*.p12)",
      "Read(**/*.pfx)",
      "Read(**/id_rsa)",
      "Read(**/id_dsa)",
      "Read(**/id_ecdsa)",
      "Read(**/id_ed25519)",
      "Read(./secrets/**)",
      "Read(./.secrets/**)",
      "Read(./credentials/**)",
      "Read(**/.aws/credentials)",
      "Read(**/serviceAccountKey.json)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "^(Read|Edit|Grep)$",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/secret-guard.js"
          }
        ]
      }
    ]
  }
}
